--// ESP
local ESP_RENDER_DISTANCE = 150
local espObjects = {}

local function shouldIgnoreInstance(inst)
    local n = inst.Name
    if n=="TricksterDoor" or n=="MonsterLocker" or n=="ServerDoor" then return true end
    if inst.Parent then
        local pn = inst.Parent.Name
        if (n=="Door" or n=="Locker") and (pn=="TricksterDoor" or pn=="MonsterLocker" or pn=="ServerDoor") then return true end
    end
    return false
end

local function createESP(inst, color, text, hl)
    if inst:FindFirstChild("_ESPHighlight") or inst:FindFirstChild("_ESPBoard") or espObjects[inst] then return end
    local highlight
    if hl then
        highlight = Instance.new("Highlight")
        highlight.Name = "_ESPHighlight"
        highlight.FillColor = color
        highlight.FillTransparency = 0.65
        highlight.OutlineColor = Color3.new(1,1,1)
        highlight.OutlineTransparency = 0.15
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Parent = inst
    end
    local attach = inst
    local posSource
    if inst:IsA("Model") then
        local p = inst.PrimaryPart or inst:FindFirstChildWhichIsA("BasePart")
        if p then attach = p; posSource = p end
    elseif inst:IsA("BasePart") then posSource = inst end
    local bb = Instance.new("BillboardGui")
    bb.Name = "_ESPBoard"; bb.AlwaysOnTop = true; bb.Size = UDim2.new(0,120,0,24)
    bb.StudsOffsetWorldSpace = Vector3.new(0,2.5,0); bb.LightInfluence = 0; bb.Parent = attach
    local lbl = Instance.new("TextLabel")
    lbl.Text = text; lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 13; lbl.TextColor3 = color
    lbl.BackgroundTransparency = 1; lbl.Size = UDim2.new(1,0,1,0); lbl.TextXAlignment = Enum.TextXAlignment.Center
    lbl.TextStrokeTransparency = 0.35; lbl.TextStrokeColor3 = Color3.new(0,0,0); lbl.Parent = bb
    espObjects[inst] = {billboard=bb, highlight=highlight, attachPoint=attach, posSource=posSource, color=color, lastInRange=nil}
end

local function destroyESP(inst)
    local d = espObjects[inst]
    if d then
        if d.highlight then d.highlight:Destroy() end
        if d.billboard then d.billboard:Destroy() end
        espObjects[inst] = nil
    else
        local h = inst:FindFirstChild("_ESPHighlight"); if h then h:Destroy() end
        local b = inst:FindFirstChild("_ESPBoard"); if b then b:Destroy() end
    end
end

task.spawn(function()
    while task.wait(1) do
        local char = LP.Character; if not char then continue end
        local root = char:FindFirstChild("HumanoidRootPart"); if not root then continue end
        local pp = root.Position
        local staleKeys = {}
        for inst, esp in pairs(espObjects) do
            if not inst or not inst.Parent then
                if esp.highlight then pcall(function() esp.highlight:Destroy() end) end
                if esp.billboard then pcall(function() esp.billboard:Destroy() end) end
                staleKeys[#staleKeys+1] = inst
            end
        end
        for _, inst in ipairs(staleKeys) do espObjects[inst] = nil end
        for inst, esp in pairs(espObjects) do
            if not inst or not inst.Parent then continue end
            -- Entity ESP ignores render distance — always visible
            if esp.isEntity then continue end
            -- Resolve posSource dynamically in case the Model had no BasePart at creation time
            local src = esp.posSource
            if not src or not src.Parent then
                if inst:IsA("Model") then
                    local p = inst.PrimaryPart or inst:FindFirstChildWhichIsA("BasePart")
                    if p then esp.posSource = p; src = p end
                end
            end
            local inRange
            if src and src.Parent then
                inRange = (pp - src.Position).Magnitude <= ESP_RENDER_DISTANCE
            else
                -- Last resort: use GetPivot for models still lacking a BasePart
                local ok, cf = pcall(function() return inst:GetPivot() end)
                if not ok then continue end
                inRange = (pp - cf.Position).Magnitude <= ESP_RENDER_DISTANCE
            end
            if esp.lastInRange ~= inRange then
                esp.lastInRange = inRange
                if esp.billboard then esp.billboard.Enabled = inRange end
                if esp.highlight then esp.highlight.Enabled = inRange end
            end
        end
    end
end)

-- Generic ESP toggle factory
local function makeESPToggle(box, id, text, nameMap, color, parent, showHL)
    parent = parent or workspace.GameplayFolder.Rooms
    box:AddToggle(id, {Text=text, Default=false, Callback=function(v)
        if v then
            trackConnection(id, parent.DescendantAdded:Connect(function(inst)
                if not shouldIgnoreInstance(inst) and nameMap[inst.Name] then createESP(inst, color, nameMap[inst.Name], showHL) end
            end))
            for _, inst in ipairs(parent:GetDescendants()) do
                if not shouldIgnoreInstance(inst) and nameMap[inst.Name] then createESP(inst, color, nameMap[inst.Name], showHL) end
            end
        else
            removeConnection(id)
            for _, inst in ipairs(parent:GetDescendants()) do if nameMap[inst.Name] then destroyESP(inst) end end
        end
    end})
end

