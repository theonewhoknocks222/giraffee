-- Anti Doppel
-- From decompiled code: Doppel fires ReplicatedStorage.Events.Doppel on the client
-- to trigger Spawn(), and renders itself into a ViewportFrame in PlayerGui called "Doppel".
-- We block the remote, destroy the ViewportFrame UI, and patch the moveFunction back
-- so controls aren't inverted if Contact() already fired before the toggle was on.
AntiModBox:AddToggle("AntiDoppel", {
    Text = "Anti Doppel", Default = false,
    Callback = function(v)
        if v then
            pcall(function()
                local events = game:GetService("ReplicatedStorage"):WaitForChild("Events", 5)
                if events then
                    local doppelRemote = events:FindFirstChild("Doppel")
                    if doppelRemote then
                        -- Intercept the OnClientEvent so Doppel.Spawn() never runs
                        trackConnection("AntiDoppelRemote", doppelRemote.OnClientEvent:Connect(function()
                            -- Immediately clean up the ViewportFrame Doppel renders into
                            pcall(function()
                                local doppelGui = LP.PlayerGui:FindFirstChild("Main")
                                if doppelGui then
                                    local doppelFrame = doppelGui.UI.Parent:FindFirstChild("Doppel")
                                    if doppelFrame then
                                        local vp = doppelFrame:FindFirstChildWhichIsA("ViewportFrame")
                                        if vp then vp.CurrentCamera = nil end
                                    end
                                end
                            end)
                            -- Restore movement controls in case Contact() already inverted them
                            pcall(function()
                                local controls = require(LP:WaitForChild("PlayerScripts"):WaitForChild("PlayerModule")):GetControls()
                                controls.moveFunction = LP.Move
                            end)
                        end))
                    end
                end
            end)
            -- Also watch workspace for any Doppel model and destroy it
            startEntityCheckLoop("AntiDoppel", function(i)
                local n = i.Name:lower()
                return n == "doppel" or n:find("^doppel") or n == "doppelganger"
            end, workspace)
        else
            removeConnection("AntiDoppelRemote")
            stopEntityCheckLoop("AntiDoppel")
        end
    end,
})

