    local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,8); c.Parent=btn
    local s=Instance.new("UIStroke"); s.Color=strokeColor; s.Thickness=1.5; s.Parent=btn
    btn.MouseButton1Click:Connect(onClick)
    local dragging,dragStart,startPos = false,nil,nil
    btn.InputBegan:Connect(function(i)
        if mobileHideLocked then return end
        if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then
            dragging=true; dragStart=i.Position; startPos=btn.Position
        end
    end)
    btn.InputChanged:Connect(function(i)
        if not dragging then return end
        if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseMovement then
            local d=i.Position-dragStart; btn.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,startPos.Y.Scale,startPos.Y.Offset+d.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
    end)
    return btn
end

