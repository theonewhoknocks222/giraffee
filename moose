local function makeDraggableBtn(parent, name, text, bgColor, strokeColor, yOffset, onClick)
    local btn = Instance.new("TextButton")
    btn.Name=name; btn.Size=UDim2.new(0,120,0,44); btn.Position=UDim2.new(0,20,0.5,yOffset)
    btn.BackgroundColor3=bgColor; btn.BorderSizePixel=0; btn.Text=text
