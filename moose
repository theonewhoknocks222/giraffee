--// ─── PRE-ROUND SHOP TAB ───
local PRS_Left  = Tabs.PreRound:AddLeftGroupbox("Purchase")
local PRS_Right = Tabs.PreRound:AddRightGroupbox("Item Select")

PRS_Right:AddLabel("Only usable in the submarine\nwhile the shop is shown.", true)

-- Dynamically read items from ReplicatedStorage.PreRoundShop
-- Returns {name -> IntValue} for all direct IntValue children
local function getPRSItems()
    local items = {}
    local prs = game:GetService("ReplicatedStorage"):FindFirstChild("PreRoundShop")
    if not prs then return items end
    for _, child in ipairs(prs:GetChildren()) do
        if child:IsA("IntValue") then
            items[child.Name] = child
        end
    end
    return items
end

local function getPRSNames()
    local names = {}
    for name in pairs(getPRSItems()) do
        -- Skip any battery-named items from the shop itself — we add Batteries manually
        if not name:lower():find("battery") then
            names[#names+1] = name
        end
    end
    table.sort(names)
    -- Always add Batteries as a manual entry since it's always purchasable
    names[#names+1] = "Batteries"
    if #names == 1 then table.insert(names, 1, "(shop not available)") end
    return names
end

-- Right box: item selector dropdown + confirm button
PRS_Right:AddDropdown("PRSItemSelect", {
    Values = getPRSNames(),
    Default = 1,
    Multi = true,
    Text = "Select Items",
    Callback = function(_) end,
})

-- Sliders and cost label — rebuilt each time Confirm is pressed
local _prsSliders = {}       -- name -> slider option object
local _prsSelection = {}     -- ordered list of selected item names
local _prsCostLabel = nil

local function rebuildPRSLeft()
    -- Clear existing sliders and label
    -- The library doesn't support removing elements so we track and hide them
    for _, s in pairs(_prsSliders) do
        pcall(function() s:SetValue(1) end)
    end
    _prsSliders = {}
    _prsSelection = {}

    local selected = Options.PRSItemSelect and Options.PRSItemSelect.Value or {}
    local items = getPRSItems()
    local hasBattery = false

    for name, isOn in pairs(selected) do
        if isOn and name ~= "(shop not available)" then
            if name == "Batteries" or name:lower():find("battery") then
                hasBattery = true
            end
            _prsSelection[#_prsSelection+1] = name
        end
    end
    table.sort(_prsSelection)

    -- Add a slider for each selected item
    for _, name in ipairs(_prsSelection) do
        local isBat = name == "Batteries" or name:lower():find("battery")
        local maxAmt = isBat and 5 or 3
        local sliderId = "PRSSlider_"..name
        PRS_Left:AddSlider(sliderId, {
            Text = "Amount: "..name,
            Default = 1, Min = 1, Max = maxAmt, Rounding = 0,
            Callback = function(_) end,
        })
        _prsSliders[name] = Options[sliderId]
    end

    -- Cost label
    if not _prsCostLabel then
        _prsCostLabel = PRS_Left:AddLabel("Total cost: —", true)
    end
end

PRS_Right:AddButton({Text="Confirm Selection", Func=function()
    rebuildPRSLeft()
    Library:Notify("Selection confirmed. Set amounts then Buy.", 4)
end})

-- Left box: cost display + buy button
PRS_Left:AddButton({Text="Calculate Cost", Func=function()
    local items = getPRSItems()
    local total = 0
    for name, slider in pairs(_prsSliders) do
        local item = items[name]
        local amt = slider and slider.Value or 1
        if item then total = total + (item.Value * amt) end
    end
    if _prsCostLabel then
        pcall(function() _prsCostLabel:SetText("Total cost: "..tostring(total).." Kroner") end)
    end
    Library:Notify("Total cost: "..tostring(total).." Kroner", 4)
end})

PRS_Left:AddButton({Text="Buy Items", Func=function()
    local items = getPRSItems()
    if #_prsSelection == 0 then
        Library:Notify("No items selected. Press Confirm Selection first.", 4)
        return
    end

    -- Build Items table (non-battery) and Batteries count separately
    local itemsTable = {}
    local batteriesCount = 0

    for name, slider in pairs(_prsSliders) do
        local amt = slider and slider.Value or 1
        if name == "Batteries" or name:lower():find("battery") then
            batteriesCount = batteriesCount + amt
        else
            itemsTable[name] = amt
        end
    end

    pcall(function()
        game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("PreRoundShop"):FireServer({
            Items = itemsTable,
            Batteries = batteriesCount,
        })
    end)

    Library:Notify("Purchase sent!", 4)
end})

