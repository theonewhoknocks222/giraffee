local function makeAutoInteract(toggleId, nameMap, connName, stateRef, shopGuard)
    local function handle(inst, state)
        if not inst:IsA("ProximityPrompt") then return end
        local pname = inst.Parent.Parent and inst.Parent.Parent.Name or ""
        if not nameMap[pname] then return end
        if shopGuard and isInShop(inst) then return end
        inst.HoldDuration=0; inst.MaxActivationDistance=10
        task.spawn(function()
            while stateRef[1] and task.wait(0.1) do
                if LP:DistanceFromCharacter(inst.Parent.Position)<=10 then fireproximityprompt(inst) end
            end
        end)
    end
    AutoBox:AddToggle(toggleId,{Text="Auto Interact "..toggleId:gsub("AutoInteract",""),Default=false,Callback=function(v)
        stateRef[1]=v
        if v then
            trackConnection(connName, workspace.GameplayFolder.Rooms.DescendantAdded:Connect(function(i) handle(i, stateRef) end))
            for _, i in ipairs(workspace.GameplayFolder.Rooms:GetDescendants()) do handle(i, stateRef) end
        else removeConnection(connName) end
    end})
end

