local HuntedBox = Tabs.Removal:AddLeftGroupbox("The Hunted")

HuntedBox:AddToggle("AntiRebarb", {
    Text = "Anti Rebarb", Default = false,
    Callback = function(v)
        if v then
            -- Find which room the local player is currently inside by checking
            -- which room model's bounding box contains (or is closest to) the player.
            local function getCurrentRoom()
                local char = LP.Character
                if not char then return nil end
                local root = char:FindFirstChild("HumanoidRootPart")
                if not root then return nil end
                local pp = root.Position
                local rooms = workspace:FindFirstChild("GameplayFolder") and workspace.GameplayFolder:FindFirstChild("Rooms")
                if not rooms then return nil end

                local bestRoom, bestDist = nil, math.huge
                for _, room in ipairs(rooms:GetChildren()) do
                    if room:IsA("Model") then
                        -- Use GetBoundingBox to find the room's centre and size
                        local ok, cf, size = pcall(function() return room:GetBoundingBox() end)
                        if ok then
                            -- Check if player is inside the bounding box (with a small margin)
                            local local_pos = cf:PointToObjectSpace(pp)
                            local half = size / 2
                            if math.abs(local_pos.X) <= half.X + 10
                            and math.abs(local_pos.Y) <= half.Y + 10
                            and math.abs(local_pos.Z) <= half.Z + 10 then
                                local dist = (cf.Position - pp).Magnitude
                                if dist < bestDist then
                                    bestDist = dist
                                    bestRoom = room
                                end
                            end
                        end
                    end
                end
                -- Fallback: if no bounding-box match, just return the closest room
                if not bestRoom then
                    for _, room in ipairs(rooms:GetChildren()) do
                        if room:IsA("Model") then
                            local ok, cf = pcall(function() return room:GetPivot() end)
                            if ok then
                                local dist = (cf.Position - pp).Magnitude
                                if dist < bestDist then bestDist = dist; bestRoom = room end
                            end
                        end
                    end
                end
                return bestRoom
            end

            local equipRemote = game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("Equip")
            local lastRebarbCheck = 0
            local lastRebarbFire  = 0
            local rebarbPresent   = false  -- true only when RebarRoot is in the current room

            -- Check for Rebarb at 2Hz (cheap) — only fire remotes when actually detected
            trackConnection("AntiRebarb", RunService.Heartbeat:Connect(function()
                local now = tick()

                -- Detection pass: every 0.5s check if RebarRoot exists in current room
                if now - lastRebarbCheck >= 0.5 then
                    lastRebarbCheck = now
                    pcall(function()
                        local room = getCurrentRoom()
                        rebarbPresent = room ~= nil and room:FindFirstChild("RebarRoot") ~= nil
                    end)
                end

                -- Only fire when Rebarb is present, and throttle to ~10Hz
                if not rebarbPresent then return end
                if now - lastRebarbFire < 0.1 then return end
                lastRebarbFire = now

                pcall(function()
                    -- Re-equip so switching items doesn't break it
                    equipRemote:FireServer("FlashBeaconHighGrade")
                    local room = getCurrentRoom()
                    if not room then return end
                    local rebarRoot = room:FindFirstChild("RebarRoot")
                    if not rebarRoot then rebarbPresent = false; return end
                    local attackRemote = rebarRoot:FindFirstChild("Events") and rebarRoot.Events:FindFirstChild("Attack")
                    if attackRemote then attackRemote:FireServer() end
                end)
            end))
        else
            removeConnection("AntiRebarb")
        end
    end,
})

