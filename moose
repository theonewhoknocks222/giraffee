-- Dedup tables: track recently fired labels so DescendantAdded firing for sub-instances
-- of the same entity model doesn't produce duplicate notifications.
local _notifyRecentSpawn  = {}
local _notifyRecentDespawn = {}
local _chatRecentSpawn    = {}
local _chatRecentDespawn  = {}
local NOTIFY_COOLDOWN = 2 -- seconds before the same label can fire again

local function canFire(tbl, label)
    local now = tick()
    if tbl[label] and (now - tbl[label]) < NOTIFY_COOLDOWN then return false end
    tbl[label] = now
    return true
end

