                local equipRemote     = events:FindFirstChild("Equip")
                local toggleScream    = events:FindFirstChild("DoombringerToggleScream")
                local squeakRemote    = events:FindFirstChild("DoombringerSqueak")

                local screamTimeRemote = events:FindFirstChild("RequestDoombringerScreamTime")

                local function silenceDoombringer()
                    -- Must be holding Doombringer for Activate to register on the server.
                    -- Equip first, then fire Activate — same as the player left-clicking.
                    pcall(function()
                        if equipRemote then equipRemote:FireServer("Doombringer") end
                    end)
                    -- Invoke RequestDoombringerScreamTime with the local player — mirrors
                    -- what UnequipFunction does to sync scream state server-side.
                    pcall(function()
                        if screamTimeRemote then screamTimeRemote:InvokeServer(LP) end
                    end)
                    task.wait(0.05) -- small gap so equip/sync processes before activate
                    if activateRemote then
                        pcall(function() activateRemote:FireServer("Doombringer") end)
                    end
                end

                -- Watch workspace for a Doombringer model/part being held by the local
                -- player and auto-equip+silence as soon as it appears.
                trackConnection("AntiDoombringerDetect", workspace.DescendantAdded:Connect(function(inst)
                    local n = inst.Name:lower()
                    if n == "doombringer" or n:find("doombringer") then
                        task.wait(0.1) -- let the item finish loading
                        pcall(function()
                            if equipRemote then equipRemote:FireServer("Doombringer") end
                        end)
                    end
                end))

                -- Primary: intercept the scream toggle remote
                if toggleScream then
                    trackConnection("AntiDoombringerScream", toggleScream.OnClientEvent:Connect(function(screaming)
                        if screaming then
                            -- Fire immediately, then again after a short delay as a safety net
                            silenceDoombringer()
                            task.delay(0.15, silenceDoombringer)
                        end
                    end))
                end

                -- Secondary: DoombringerSqueak fires when Pandemonium interrupts the scream
                -- server-side — silence in that case too just to be safe
                if squeakRemote then
                    trackConnection("AntiDoombringerSqueak", squeakRemote.OnClientEvent:Connect(function()
                        silenceDoombringer()
                    end))
                end
            end)
        else
            removeConnection("AntiDoombringerDetect")
            removeConnection("AntiDoombringerScream")
            removeConnection("AntiDoombringerSqueak")
        end
    end,
})

