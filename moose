local AH = {enabled=false,isHiding=false,spectate=false,quickReturn=false,activeEntities={},safePlatform=nil,originalCFrame=nil,spectateTarget=nil,spectateViewOffset=Vector3.new(0,5,0),originMarker=nil,originHL=nil,originAdornGui=nil}

local function ahForceReturn()
    if not AH.isHiding then return end
    AH.isHiding=false; _Flags.HideActive=false; AH.activeEntities={}; AH.spectateTarget=nil
    pcall(function()
        if not LP.Character then return end
        local root = LP.Character:FindFirstChild("HumanoidRootPart")
        if root and AH.originalCFrame then root.CFrame = AH.originalCFrame end
        AH.originalCFrame = nil
        if AH.safePlatform then AH.safePlatform:Destroy(); AH.safePlatform=nil end
        if AH.originHL then AH.originHL:Destroy(); AH.originHL=nil end
        if AH.originMarker then AH.originMarker:Destroy(); AH.originMarker=nil end
        if AH.originAdornGui then AH.originAdornGui:Destroy(); AH.originAdornGui=nil end
    end)
    Library:Notify("Force returned to position!", 4)
end

local function ahStartHiding()
    if AH.isHiding then return end
    AH.isHiding=true; _Flags.HideActive=true
    pcall(function()
        if not LP.Character then return end
        local hum = LP.Character:FindFirstChild("Humanoid")
        local root = LP.Character:FindFirstChild("HumanoidRootPart")
        if not hum or not root then return end
        AH.originalCFrame = root.CFrame
        -- Force off fly if active so BodyVelocity doesn't fight the teleport
        if _Flags.FlyActive and Toggles.EnableFly then
            Toggles.EnableFly:SetValue(false)
            task.wait(0.1)
        end
        -- Force off PlatformStand (swimming state) so the tp isn't blocked
        if hum.PlatformStand then hum.PlatformStand=false; task.wait(0.3) end
        -- Also reset humanoid state to ensure we're not in a swimming state
        pcall(function() hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        task.wait(0.1)
        root.CFrame = root.CFrame + Vector3.new(0,2000,0); task.wait(0.1)
        AH.safePlatform = Instance.new("Part")
        AH.safePlatform.Size = Vector3.new(100,1,100)
        AH.safePlatform.Position = root.Position - Vector3.new(0,5,0)
        AH.safePlatform.Anchored = true; AH.safePlatform.CanCollide = true; AH.safePlatform.Parent = workspace
        Library:Notify("Auto-hide activated!", 4)
    end)
    task.defer(function()
        pcall(function()
            if not AH.originalCFrame then return end
            if AH.originHL then AH.originHL:Destroy(); AH.originHL=nil end
            if AH.originMarker then AH.originMarker:Destroy() end
            if AH.originAdornGui then AH.originAdornGui:Destroy() end
            local originPos = AH.originalCFrame.Position
            -- Cylinder marker — Highlight parented to workspace so it renders through walls
            local marker = Instance.new("Part")
            marker.Name="_AHOriginMarker"
            marker.Shape = Enum.PartType.Cylinder
            marker.Size = Vector3.new(300, 1.5, 1.5)
            marker.CFrame = CFrame.new(originPos + Vector3.new(0,150,0)) * CFrame.Angles(0,0,math.pi/2)
            marker.Anchored = true; marker.CanCollide = false; marker.CanTouch = false
            marker.Material = Enum.Material.Neon
            marker.Color = Color3.fromRGB(0,220,255)
            marker.Transparency = 0 -- must be visible for Highlight to render it
            marker.Parent = workspace
            -- Highlight parented directly to workspace so it renders the adornee through walls
            local hl = Instance.new("Highlight")
            hl.FillColor = Color3.fromRGB(0,220,255)
            hl.FillTransparency = 0.4
            hl.OutlineColor = Color3.fromRGB(0,220,255)
            hl.OutlineTransparency = 0
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.Adornee = marker
            hl.Parent = workspace
            -- BillboardGui label above the marker
            local bb = Instance.new("BillboardGui")
            bb.AlwaysOnTop = true; bb.Size = UDim2.new(0,150,0,32)
            bb.StudsOffsetWorldSpace = Vector3.new(0,152,0); bb.LightInfluence = 0; bb.Parent = marker
            local lbl = Instance.new("TextLabel")
            lbl.Text = "▼ Last Position"; lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 13
            lbl.TextColor3 = Color3.fromRGB(0,220,255); lbl.BackgroundTransparency = 1
            lbl.Size = UDim2.new(1,0,1,0); lbl.TextStrokeTransparency = 0.3
            lbl.TextStrokeColor3 = Color3.new(0,0,0); lbl.Parent = bb
            AH.originMarker = marker; AH.originHL = hl; AH.originAdornGui = nil
        end)
    end)
end

local function ahStopHiding()
    if not AH.isHiding then return end
    task.wait(0.5); if next(AH.activeEntities) ~= nil then return end
    AH.isHiding=false; _Flags.HideActive=false; AH.spectateTarget=nil
    pcall(function()
        if not LP.Character then return end
        local root = LP.Character:FindFirstChild("HumanoidRootPart")
        if not root or not AH.originalCFrame then return end
        root.CFrame = AH.originalCFrame; AH.originalCFrame=nil; task.wait(0.1)
        if AH.safePlatform then AH.safePlatform:Destroy(); AH.safePlatform=nil end
        if AH.originHL then AH.originHL:Destroy(); AH.originHL=nil end
            if AH.originMarker then AH.originMarker:Destroy(); AH.originMarker=nil end
            if AH.originAdornGui then AH.originAdornGui:Destroy(); AH.originAdornGui=nil end
        Library:Notify("All entities gone — returned!", 4)
    end)
end

