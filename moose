--// Entity loop helpers — consolidated dispatcher
-- All active removal checks share ONE DescendantAdded connection per parent and ONE
-- poll loop per parent, rather than each toggle having its own. This cuts the number
-- of firing connections and GetDescendants() calls down to 2-3 regardless of how many
-- removal toggles are on simultaneously.

local EntityLoopFlags = {}  -- name -> checkFn when active, false when stopped
local _removalParents = {}  -- parent -> {connKey, pollKey, checks={name->checkFn}}

local function _getOrCreateParentEntry(parent)
    if _removalParents[parent] then return _removalParents[parent] end
    local entry = {checks = {}}
    _removalParents[parent] = entry

    -- Single shared DescendantAdded connection for this parent
    local connKey = tostring(parent) .. "_shared_added"
    trackConnection(connKey, parent.DescendantAdded:Connect(function(inst)
        -- task.wait() lets the instance fully parent before checking
        task.wait()
        if not inst or not inst.Parent then return end
        for _, checkFn in pairs(entry.checks) do
            if checkFn(inst) then pcall(function() inst:Destroy() end); return end
        end
    end))
    entry.connKey = connKey

    -- Single shared poll loop for non-workspace parents (Rooms/Monsters)
    -- Poll at 5s instead of 3s — the DescendantAdded catches most things instantly
    if parent ~= workspace then
        local pollKey = tostring(parent) .. "_shared_poll"
        entry.pollKey = pollKey
        task.spawn(function()
            while _removalParents[parent] do
                task.wait(5)
                if not _removalParents[parent] then break end
                pcall(function()
                    for _, inst in ipairs(parent:GetDescendants()) do
                        for _, checkFn in pairs(entry.checks) do
                            if checkFn(inst) then pcall(function() inst:Destroy() end); break end
                        end
                    end
                end)
            end
        end)
    end
    return entry
end

local function _cleanupParentIfEmpty(parent)
    local entry = _removalParents[parent]
    if not entry then return end
    if next(entry.checks) ~= nil then return end
    -- No checks left — disconnect the shared connection and remove the entry
    removeConnection(entry.connKey)
    _removalParents[parent] = nil
end

local function startEntityCheckLoop(name, checkFn, parent)
    EntityLoopFlags[name] = checkFn
    -- Initial sweep
    for _, inst in ipairs(parent:GetDescendants()) do
        if checkFn(inst) then pcall(function() inst:Destroy() end) end
    end
    local entry = _getOrCreateParentEntry(parent)
    entry.checks[name] = checkFn
end

local function stopEntityCheckLoop(name)
    local checkFn = EntityLoopFlags[name]
    EntityLoopFlags[name] = false
    -- Remove from whichever parent entry holds this check
    for parent, entry in pairs(_removalParents) do
        if entry.checks[name] then
            entry.checks[name] = nil
            _cleanupParentIfEmpty(parent)
            break
        end
    end
end

