-- Special: A200 — client-side entity; trick it into self-destructing by setting
-- Main.Locker = true (the same check the script uses when the player hides in a locker),
-- then also nil out LocalEntities.A200 and destroy the model directly as a fallback.
AntiModBox:AddToggle("RemoveA200",{Text="Remove A-200",Default=false,Callback=function(v)
    local function killA200()
        pcall(function()
            local main = require(LP.PlayerGui.Main.Client.MainClient)
            -- Setting Locker=true makes A200's PathFindToPlayer loop self-destruct cleanly
            if main then
                main.Locker = true
                task.delay(0.5, function() main.Locker = false end)
                -- Also nil the LocalEntities reference so it doesn't re-path
                if main.LocalEntities then main.LocalEntities.A200 = nil end
            end
        end)
        -- Hard fallback: destroy any A200 model in workspace directly
        pcall(function()
            for _, inst in ipairs(workspace:GetChildren()) do
                local n = inst.Name:lower()
                if n == "a200" or n == "a-200" or n:find("^a200") then
                    -- Stop the movement tween and unbind render steps before destroying
                    game:GetService("RunService"):UnbindFromRenderStep("A200Detect")
                    game:GetService("RunService"):UnbindFromRenderStep("playerDistance")
                    inst:Destroy()
                end
            end
        end)
    end
    if v then
        -- Kill immediately if already present
        killA200()
        -- Watch for A200 appearing
        trackConnection("RemoveA200", workspace.ChildAdded:Connect(function(inst)
            local n = inst.Name:lower()
            if n == "a200" or n == "a-200" or n:find("^a200") then
                task.wait(0.1) -- let it finish parenting
                killA200()
            end
        end))
    else
        removeConnection("RemoveA200")
    end
end})


