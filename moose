AntiModBox:AddToggle("AntiRatRace", {Text="Anti Rat Race", Default=false, Callback=function(v)
    if v then
        local _rrChaseActive = false  -- true while a chase entity is present
        local _rrChaseEntities = {}   -- tracks active chase entities

        local function restoreHealth()
            pcall(function()
                local pf = LP:FindFirstChild("PlayerFolder")
                if not pf or pf:FindFirstChild("Health") then return end
                local h = Instance.new("IntValue")
                h.Name = "Health"; h.Value = 100; h.Parent = pf
            end)
        end

        local function nukeHealth()
            pcall(function()
                local pf = LP:FindFirstChild("PlayerFolder")
                if not pf then return end
                local health = pf:FindFirstChild("Health")
                if health then health:Destroy() end
            end)
        end

        local function freezePlayer()
            pcall(function()
                local char = LP.Character; if not char then return end
                local hum = char:FindFirstChild("Humanoid")
                if hum then hum.WalkSpeed = 0; hum.JumpPower = 0 end
            end)
        end

        local function unfreezePlayer()
            pcall(function()
                local char = LP.Character; if not char then return end
                local hum = char:FindFirstChild("Humanoid")
                if hum then hum.WalkSpeed = 16; hum.JumpPower = 50 end
            end)
        end

        local function onChaseEntityGone()
            -- Only return if all chase entities are gone
            if next(_rrChaseEntities) ~= nil then return end
            _rrChaseActive = false
            -- Delete health again, unfreeze, trigger auto-hide return
            nukeHealth()
            unfreezePlayer()
            if AH.isHiding then ahStopHiding() end
        end

        local function onChaseEntitySpawned(entity, label)
            if _rrChaseEntities[entity] then return end
            _rrChaseEntities[entity] = true
            if not _rrChaseActive then
                _rrChaseActive = true
                -- Restore health so the game can read it during the chase (prevents insta-death)
                restoreHealth()
                -- Freeze the player so walking damage can't accumulate
                freezePlayer()
                -- Trigger auto-hide if it's enabled
                if Toggles.AutoHide and Toggles.AutoHide.Value then
                    ahStartHiding()
                end
                Library:Notify("[RatRace] "..label.." — health restored, frozen", 4)
            end
            -- Watch for this entity despawning
            task.spawn(function()
                entity.Destroying:Wait()
                _rrChaseEntities[entity] = nil
                task.wait(0.5)
                onChaseEntityGone()
            end)
        end

        -- Watch workspace for chase entities (same set as AutoHide)
        trackConnection("AntiRatRaceChase", workspace.DescendantAdded:Connect(function(entity)
            if not entity:IsA("Part") then return end
            local label = AutoHideEntities[entity.Name]
            if not label then
                -- Fuzzy check for variants
                local nl = entity.Name:lower()
                if nl:find("^carnation") then label = "Carnation"
                elseif nl:find("^a200$") or nl:find("^a-200$") then label = "A-200"
                elseif nl:find("^bleach") then label = "Bleach"
                elseif nl:find("anglemonium") then label = "Anglemonium"
                elseif nl:find("frogermonium") then label = "Frogermonium"
                elseif nl:find("pinkimonium") then label = "Pinkimonium"
                elseif nl:find("pandesmoker") then label = "Pandesmoker"
                elseif nl:find("blitzemonium") then label = "Blitzemonium"
                elseif nl:find("^doppel") then label = "Doppel"
                end
            end
            if label then onChaseEntitySpawned(entity, label) end
        end))

        -- Always pin TotalDamage to 0
        trackConnection("AntiRatRaceDamage", RunService.Heartbeat:Connect(function()
            pcall(function()
                local pf = LP:FindFirstChild("PlayerFolder")
                if not pf then return end
                local dmg = pf:FindFirstChild("TotalDamage")
                if dmg and dmg.Value ~= 0 then dmg.Value = 0 end
            end)
        end))

        -- Watch for Health being re-added while no chase is active — delete it
        trackConnection("AntiRatRaceHealthAdded", LP.DescendantAdded:Connect(function(inst)
            if inst.Name == "Health" and not _rrChaseActive then
                task.wait(); pcall(function() inst:Destroy() end)
            end
        end))

        -- Initial state: no chase active, delete health, pin damage
        nukeHealth()
    else
        removeConnection("AntiRatRaceChase")
        removeConnection("AntiRatRaceDamage")
        removeConnection("AntiRatRaceHealthAdded")
        -- Restore everything on disable
        pcall(function()
            local char = LP.Character
            if char then
                local hum = char:FindFirstChild("Humanoid")
                if hum then hum.WalkSpeed = 16; hum.JumpPower = 50 end
            end
        end)
        pcall(function()
            local pf = LP:FindFirstChild("PlayerFolder")
            if not pf then return end
            if not pf:FindFirstChild("Health") then
                local h = Instance.new("IntValue")
                h.Name = "Health"; h.Value = 100; h.Parent = pf
            end
        end)
    end
end})

-- Remove Carnation
AntiModBox:AddToggle("RemoveCarnation", {Text="Remove Carnation", Default=false, Callback=function(v)
    if v then
        -- Carnation is a Model — watch workspace.ChildAdded for the model directly,
        -- and also scan existing children. DescendantAdded fires for Parts inside the model
        -- before the model itself in some cases, so we check both the instance and its parent.
        local function killCarnation(inst)
            if not inst or not inst.Parent then return end
            local function isCarnation(obj)
                local n = obj.Name:lower()
                return n == "carnation" or n:find("^carnation")
            end
            if isCarnation(inst) then
                pcall(function() inst:Destroy() end)
            elseif inst.Parent and isCarnation(inst.Parent) then
                pcall(function() inst.Parent:Destroy() end)
            end
        end
        -- Initial sweep
        for _, child in ipairs(workspace:GetChildren()) do killCarnation(child) end
        -- Watch for Carnation model being added to workspace
        trackConnection("RemoveCarnation_added", workspace.ChildAdded:Connect(function(child)
            task.wait()
            killCarnation(child)
        end))
        -- Also watch descendants in case it spawns nested
        trackConnection("RemoveCarnation_desc", workspace.DescendantAdded:Connect(function(inst)
            task.wait()
            if inst and inst.Parent and inst.Parent ~= workspace then
                local n = inst.Parent.Name:lower()
                if n == "carnation" or n:find("^carnation") then
                    pcall(function() inst.Parent:Destroy() end)
                end
            end
        end))
        EntityLoopFlags["RemoveCarnation"] = true
        task.spawn(function()
            while EntityLoopFlags["RemoveCarnation"] do
                task.wait(2)
                if not EntityLoopFlags["RemoveCarnation"] then break end
                for _, child in ipairs(workspace:GetChildren()) do
                    pcall(function() killCarnation(child) end)
                end
            end
        end)
    else
        EntityLoopFlags["RemoveCarnation"] = false
        removeConnection("RemoveCarnation_added")
        removeConnection("RemoveCarnation_desc")
    end
end})

